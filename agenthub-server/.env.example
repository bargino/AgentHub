# AgentHub Server 配置
# Agent 通过本地 SDK 调用（claude-agent-sdk / openai-codex），无需 API Key。
# 请确保已安装并登录对应 SDK：
#   - Claude Code: pip install claude-agent-sdk（需 claude login）
#   - Codex: pip install openai-codex（需 Codex 登录态）

# Server
HOST=0.0.0.0
PORT=8642
DEBUG=false

# 数据目录（默认 ~/.agenthub，含 data.db 和 workspaces/）
# AGENTHUB_DATA_DIR=
